---
import LayoutPage from "../layouts/LayoutPage.astro";
import Avatar from '../components/Avatar.astro';
const allPosts = await Astro.glob('../pages/notes/*.md');
let currentYear = null

// todo: fix day offset / timezone shnans
function formatPostDate(postDate) {
  const date = new Date(postDate);
  return date.toLocaleDateString('en-US', { month: 'short', day: 'numeric' });
}


---

<LayoutPage title="Notes">
    <div class="hero flex flex-col gap-8 my-8 lg:my-16 lg:my-24">
        <Avatar></Avatar>
        <div class="flex flex-col gap-2">
            <h1 class="anim-entry anim--h1 text-[32px] lg:text-[56px] font-[590] leading-[115%] -tracking-[1px] text-balance" style="text-wrap: balance;">
                Notes
            </h1>
        </div>
        <div class="anim-entry anim--body-subpage list-none list-inside leading-loose text-[16px] lg:text-[18px] font-[360] flex flex-col gap-8 lg:gap-16">
          {Object.entries(
            allPosts.reduce((acc, post) => {
              const postYear = new Date(post.frontmatter.date).getFullYear();
              if (!acc[postYear]) acc[postYear] = [];
              acc[postYear].push(post);
              return acc;
            }, {})
          )
          .sort(([yearA], [yearB]) => yearB - yearA) // Sort years in descending order
          .map(([year, posts]) => (
            <div class="">
              <h2 class="text-[14px] lg:text-[16px] font-[590] leading-[115%] -tracking-[.8px] mb-2">{year}</h2>
              <ol class="text-[16px] lg:text-[18px] font-[360] divide-y divide-[#DCDCDC]">
                {posts.reverse().map((post) => (
                  <li class="list-none flex items-center gap-8 lg:gap-12 h-12 lg:h-14">
                    <div class="whitespace-nowrap w-[72px] flex-none">

                      {
                        formatPostDate(post.frontmatter.date)
                      }
                    </div>                    
                    <a 
                      class="hover:text-[#6A6A6A] transition-all truncate"
                      href={post.url}>
                      {post.frontmatter.title}
                    </a>
                  </li>
                ))}
              </ol>
            </div>
          ))}
        </div>

    </div>
</LayoutPage>

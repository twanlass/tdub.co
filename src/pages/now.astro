---
import LayoutPage from "../layouts/LayoutPage.astro";
import Avatar from '../components/Avatar.astro';
---

<LayoutPage title="Now">
    <div class="hero flex flex-col gap-8 my-8 lg:my-16 lg:my-24">
        <Avatar></Avatar>
        <div class="anim-entry anim--h1 flex flex-col gap-2">
            <h1 class="text-[32px] lg:text-[56px] font-[590] leading-[115%] -tracking-[1px] text-balance" style="text-wrap: balance;">
                Now
            </h1>
            <p class="text-[16px] lg:text-[18px] font-[360] text-[#909090] -tracking-[.8px]">
                Last updated January 5, 2026
            </p>
        </div>
        <div class="anim-entry anim--body-subpage flex flex-col gap-8">
            <p class="text-[16px] lg:text-[18px] font-[360] max-w-prose">
                I update my now page a few times a year to share a little bit about my current state. Inspired by <a href="https://sive.rs/now">Derek Sivers</a>.
            </p>
            <ul class="list-disc ml-4 leading-loose text-[16px] lg:text-[18px] font-[360]">
                <li>Leading design at <a href="https://amplitude.com" target="_blank">Amplitude</a>.</li>
                <li>Completed a second marathon.</li>
                <li>Recently visited Costa Rica. 🏄🏻‍♂️</li>
                <li>Hacking on a personal AI assistant and a <a href="https://grog-rts.netlify.app" target="_blank">retro realtime strategy game</a>.</li>
                <li>Still renovating a <a href="https://www.instagram.com/cherrystreetrenovation/">hundred year old house</a>.</li>
                <li>Living in the Pacific Northwest with my wife, two daughters, and dog.</li>
            </ul>
        </div>
    </div>
</LayoutPage>

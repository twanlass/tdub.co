---
import { Image } from 'astro:assets';
import twLogo from "../images/tw-logo.svg";

// todo: use path to style active nav item
const {pathname} = Astro.url
---

<section class="mx-auto w-full border-t lg:border-b lg:border-t-0 border-gray-200 bg-white fixed bottom-0 lg:sticky lg:top-0 lg:bottom-auto z-10 overflow-x-scroll overflow-y-hidden" transition:animate="none">
  <div class="mx-auto max-w-6xl flex items-center">
    <a class="flex items-center justify-center px-6 lg:px-8 text-base text-gray-600 hover:text-gray-900 border-r border-l border-gray-200 h-16 opacity-70 hover:opacity-100" href="/">
      <Image 
        src={twLogo}
        width="32px"
        class="min-w-[28px]"
        alt="tdub.co logo" 
      />
    </a>
    <nav class="flex items-center justify-start h-16 lg:border-r border-gray-200 w-full">
      <ul class="inline-flex m-0 space-x-6 px-6 py-2">
        <ol class="flex m-0 gap-6 lg:gap-12">
          <a class="flex items-center justify-center text-sm lg:text-base text-gray-600 hover:text-gray-900 no-underline h-16" href="/writing">Writing <sup>01</sup></a>
          <a class="flex items-center justify-center text-sm lg:text-base text-gray-600 hover:text-gray-900 no-underline h-16" href="https://dribbble.com/twanlass" target="_blank">Design <sup>02</sup></a>
          <a class="flex items-center justify-center text-sm lg:text-base text-gray-600 hover:text-gray-900 no-underline h-16" href="/principles">Principles <sup>03</sup></a>
          <a class="flex items-center justify-center text-sm lg:text-base text-gray-600 hover:text-gray-900 no-underline h-16" href="/now">Now <sup>04</sup></a>
          <a class="flex items-center justify-center text-sm lg:text-base text-gray-600 hover:text-gray-900 no-underline h-16" href="/timeline">Timeline <sup>05</sup></a>
        </ol>
      </ul>
    </nav>
  </div>
</section>

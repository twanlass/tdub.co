---
import BaseHead from "../components/BaseHead.astro";
import Avatar from '../components/Avatar.astro';
import Nav from "../components/Nav.astro";
import Footer from "../components/Footer.astro";

const { frontmatter } = Astro.props;
// Convert the date to a more readable format
const readableDate = new Date(frontmatter.date).toLocaleDateString('en-US', {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
});

const tags = frontmatter.tags && frontmatter.tags.length > 0 ? frontmatter.tags.map(tag => `#${tag.replace(/\s+/g, '-')}`).join(' ') : '';
---

<html lang="en">
  <head>
    <BaseHead title={frontmatter.title} />
  </head>

  <body class="bg-white subpixel-antialiased">
    <main class="container mx-auto px-4 lg:px-6 lg:pt-20 max-w-screen-xl">
      <Nav></Nav>
      <div class="hero flex flex-col gap-8 mt-8 mb-4 lg:mt-24">
          <Avatar></Avatar>
          <div class="flex flex-col gap-1 w-2/3">
              <h1 class="anim-entry anim--h1 text-[24px] lg:text-[40px] font-[590] leading-[115%] -tracking-[1px]">
                  {frontmatter.title}
              </h1>
              <div class="flex flex-col lg:flex-row gap-0 lg:gap-2 text-[14px] lg:text-[16px] font-[360] text-[#909090] uppercase">
                <p>{readableDate}</p> <span class="hidden lg:block">‒</span> <p>{tags}</p>
              </div>
          </div>  
      </div>
      <article class="max-w-prose">
        <slot />
      </article>
      <Footer></Footer>
    </main>  
  </body>
</html>

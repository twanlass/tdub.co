---
import { Image } from 'astro:assets';
const { img, caption, project, cardStyles, imgStyles } = Astro.props;
---
<div class=`flex flex-col gap-2 p-3 lg:p-6 ${cardStyles}`>
    <Image 
        src={img}
        width={img.width / 2}
        densities={[1.5, 2]}
        class=`rounded-[3px] lg:rounded-[6px] select-none ${imgStyles}`
        alt={caption}
    />
    <div class="flex flex-row justify-between text-[14px] font-[360] mix-blend-darken">
        <p>{caption}</p>
        <p class="hidden lg:block">{project}</p>
    </div>
</div>
